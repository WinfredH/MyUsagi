{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyUsagi",
  "version": "0.0.1",
  "identifier": "com.myusagi.desktop",
  "build": {
    "frontendDist": "../webview/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MyUsagi",
        "width": 240,
        "height": 320,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "backgroundColor": "#00000000",
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'none'; img-src 'self' asset: http://asset.localhost data:; media-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../webview/assets.pak": "assets.pak"
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
